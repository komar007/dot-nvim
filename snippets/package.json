{
    "name": "komar's snippets",
    "engines": {
        "vscode": "^1.11.0"
    },
    "contributes": {
        "snippets": [
            {
                "language": [ "markdown" ],
                "path": "./markdown.json"
            },
            {
                "language": [ "rust" ],
                "path": "./rust.json"
            },
            {
                "language": [ "gitcommit" ],
                "path": "./gitcommit.json"
            },
            {
                "language": [ "sh" ],
                "path": "./sh.json"
            },
            {
                "language": [ "bash" ],
                "path": "./bash.json"
            }
        ]
  }
}
